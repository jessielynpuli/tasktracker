# 1. Environment & Project Databases
# Prevents your local tasks list from being pushed
*.json

# 2. Virtual Environments
# Prevents thousands of third-party dependency files from flooding your repo
.venv/
venv/
ENV/
env/

# 3. Python Bytecode & Caches
# Generated automatically by Python when running your script
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# 4. OS Specific Junk
# Hidden files generated by your operating system
.DS_Store
Thumbs.db

# 5. Build and Distribution Directories
# Generated when you run 'pip install -e .'
build/
dist/
*.egg-info/